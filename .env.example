# ============================================================
# Our Story - 环境变量配置
# 复制本文件为 .env 并填入实际值
# ============================================================

# --- 数据库 ---
DATABASE_URL=postgresql://love:love_secret@localhost:5432/love_db

# --- 认证（密码至少 6 位）---
JWT_SECRET=change-me-to-a-random-string-at-least-16-chars
USER1_USERNAME=boy
USER1_PASSWORD=your-password-here
USER1_DISPLAY_NAME=宝贝
USER2_USERNAME=girl
USER2_PASSWORD=your-password-here
USER2_DISPLAY_NAME=亲爱的

# --- AI 模型提供商（填入一个即可，优先级：环境变量 > config/ai.json）---
# 可选值：anthropic / openai / xiaomi / deepseek / qwen / zhipu / moonshot / baidu
LLM_PROVIDER=anthropic

# 各厂商 API Key（填你用的那个就行）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XIAOMI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 覆盖默认模型（可选，不填则用 config/ai.json 中的默认模型）
# LLM_MODEL=claude-sonnet-4-6
# LLM_MAX_TOKENS=600

# --- AI 服务连接（Docker 内部自动配置，本地开发时改为 localhost）---
API_BASE_URL=http://localhost:3001    # 后端 API 地址（Docker 内部用 http://server:3001）
CHROMA_PERSIST_DIR=./chroma_data      # ChromaDB 向量数据库持久化目录

# --- 服务端口（一般无需修改，改端口请修改 docker-compose.yml）---
PORT=3001                 # Node.js 后端端口（Docker 内部）
NODE_ENV=development      # development / production

# --- 日志（json=生产环境，text=开发环境可读）---
LOG_LEVEL=INFO
LOG_FORMAT=json
