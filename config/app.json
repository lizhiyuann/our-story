{
  "_comment": "应用配置 - 业务常量、模块定义、限制参数",

  "app": {
    "name": "Our Story",
    "version": "1.0.0",
    "description": "情侣浪漫网站 + AI 智能助手"
  },

  "ports": {
    "_comment": "各服务端口配置（修改 docker-compose.yml 中的端口映射即可）",
    "nginx": 80,
    "client": 3000,
    "server": 3001,
    "aiService": 8000,
    "postgres": 5432
  },

  "love": {
    "_comment": "恋爱纪念日配置，修改 startDate 为你们在一起的日期",
    "startDate": "2024-01-01T00:00:00",
    "emoji": "❤️"
  },

  "moods": {
    "_comment": "心情模块配置",
    "types": ["happy", "love", "sad", "angry", "thinking", "sleepy"],
    "emojis": {
      "happy":    "😊",
      "love":     "🥰",
      "sad":      "😢",
      "angry":    "😠",
      "thinking": "🤔",
      "sleepy":   "😴"
    }
  },

  "rants": {
    "_comment": "吐槽模块配置",
    "types": ["rant", "scold", "complain"],
    "typeNames": {
      "rant":     "吐槽",
      "scold":    "骂人",
      "complain": "抱怨"
    },
    "maxIntensity": 10
  },

  "countdown": {
    "_comment": "倒计时模块可选图标",
    "icons": [
      { "value": "🎂", "label": "生日" },
      { "value": "💕", "label": "纪念日" },
      { "value": "🎄", "label": "节日" },
      { "value": "✈️", "label": "旅行" },
      { "value": "🎓", "label": "毕业" },
      { "value": "💍", "label": "求婚" },
      { "value": "❤️", "label": "其他" }
    ]
  },

  "timeline": {
    "_comment": "时间轴模块可选图标",
    "icons": [
      { "value": "💕", "label": "相爱" },
      { "value": "🎉", "label": "庆祝" },
      { "value": "✈️", "label": "旅行" },
      { "value": "🍽️", "label": "约会" },
      { "value": "🎬", "label": "电影" },
      { "value": "🎵", "label": "音乐" },
      { "value": "📸", "label": "拍照" },
      { "value": "❤️", "label": "其他" }
    ]
  },

  "photos": {
    "_comment": "相册上传限制",
    "maxSizeMB": 5,
    "allowedTypes": ["image/jpeg", "image/png", "image/webp"],
    "thumbnailWidth": 400,
    "maxWidth": 2000
  },

  "chat": {
    "_comment": "聊天模块限制",
    "maxHistoryLength": 20,
    "maxMessageLength": 2000
  }
}
